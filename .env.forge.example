# ── Forge hosted API (Netlify env) ────────────────────────────────────────────
# Set these in Netlify → Site settings → Environment variables. NEVER commit real values.

# Per-tenant auth + metering (recommended). When set, the single-key model is bypassed.
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__   # server-only; never expose to the browser

# Legacy single-key fallback (used ONLY if SUPABASE_URL is unset). Avoid for production.
# FORGE_API_KEY=__one_shared_key__

# Server-held provider keys — callers never send these.
FORGE_PLACES_KEY=__google_places_api_new_key__    # the only lead source
FORGE_LLM_PROVIDER=groq                            # groq | google | openrouter | cerebras | anthropic
FORGE_LLM_MODEL=llama-3.3-70b-versatile
FORGE_LLM_KEY=__llm_provider_key__
FORGE_HUNTER_KEY=__optional__
FORGE_ABSTRACT_EMAIL_KEY=__optional__
FORGE_ABSTRACT_PHONE_KEY=__optional__

# Comma-separated allowlist for CORS. Default '*'. Lock to your domains for production.
FORGE_ALLOWED_ORIGINS=https://forge-lead-intelligence.netlify.app

# ── App (Vite, build-time) ────────────────────────────────────────────────────
# Client gate passphrase (interim; replace with real accounts).
VITE_APP_PASS=__change_me__

# ── App auth (Supabase, build-time public values) ─────────────────────────────
# These are the PUBLIC publishable/anon key + URL — safe to ship in the browser.
VITE_SUPABASE_URL=https://rjgeedzpqcbylgnxwxml.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_kMy9fvicd9yIoN7NupGahg_h0tfFqGh

# ── Stripe billing (server) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test___
STRIPE_WEBHOOK_SECRET=whsec___              # from the Stripe webhook endpoint
STRIPE_PRICE_STARTER=price_1TmbtY30ZX4yVabANftJOnkw   # Forge Starter $49/mo (TEST mode)
STRIPE_PRICE_PRO=price_1TmbtY30ZX4yVabAGqsYSDEO       # Forge Pro $149/mo (TEST mode)
APP_URL=https://forge-lead-intelligence.netlify.app
