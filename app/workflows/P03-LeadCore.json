{
  "name": "P03 LeadCore — AI Lead Qualification & CRM Push",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "leadcore-{{CLIENT_ID}}",
        "authentication": "headerAuth",
        "options": {}
      },
      "id": "trigger-webhook",
      "name": "Webhook — Inbound Lead",
      "type": "n8n-nodes-base.webhook",
      "position": [0, 300]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a B2B lead qualification system. Score and qualify leads against the client's ICP.\n\nICP Criteria:\n{{CLIENT_ICP_CRITERIA}}\n\nReturn JSON:\n{\n  \"score\": 1-10,\n  \"qualified\": true|false,\n  \"tier\": \"hot|warm|cold\",\n  \"company_fit\": \"description of fit\",\n  \"next_action\": \"string — what sales should do\",\n  \"personalized_email_opener\": \"1-2 sentences referencing their specific situation\",\n  \"disqualification_reason\": \"string|null\"\n}"
            },
            {
              "role": "user",
              "content": "=Lead data:\nName: {{ $json.body.name }}\nEmail: {{ $json.body.email }}\nCompany: {{ $json.body.company }}\nRole: {{ $json.body.role }}\nMessage: {{ $json.body.message }}\nSource: {{ $json.body.source }}"
            }
          ]
        },
        "options": { "response": { "response": { "responseFormat": "json" } } }
      },
      "id": "gpt-qualify",
      "name": "GPT-4o — Qualify Lead",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "credentials": { "openAiApi": { "id": "{{CLIENT_OPENAI_CRED_ID}}", "name": "OpenAI API" } },
      "position": [200, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.message.content.qualified }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ]
        }
      },
      "id": "if-qualified",
      "name": "Qualified?",
      "type": "n8n-nodes-base.if",
      "position": [400, 300]
    },
    {
      "parameters": {
        "resource": "contact",
        "operation": "create",
        "additionalFields": {
          "email": "={{ $('Webhook — Inbound Lead').item.json.body.email }}",
          "firstname": "={{ $('Webhook — Inbound Lead').item.json.body.name.split(' ')[0] }}",
          "lastname": "={{ $('Webhook — Inbound Lead').item.json.body.name.split(' ').slice(1).join(' ') }}",
          "company": "={{ $('Webhook — Inbound Lead').item.json.body.company }}",
          "jobtitle": "={{ $('Webhook — Inbound Lead').item.json.body.role }}",
          "hs_lead_status": "NEW",
          "curcible_score": "={{ $('GPT-4o — Qualify Lead').item.json.message.content.score }}",
          "curcible_tier": "={{ $('GPT-4o — Qualify Lead').item.json.message.content.tier }}",
          "curcible_next_action": "={{ $('GPT-4o — Qualify Lead').item.json.message.content.next_action }}"
        }
      },
      "id": "hubspot-create-contact",
      "name": "HubSpot — Create Contact",
      "type": "n8n-nodes-base.hubspot",
      "credentials": { "hubspotApi": { "id": "{{CLIENT_HUBSPOT_CRED_ID}}", "name": "HubSpot API" } },
      "position": [600, 200]
    },
    {
      "parameters": {
        "sendTo": "={{ $('Webhook — Inbound Lead').item.json.body.email }}",
        "subject": "={{ $('Webhook — Inbound Lead').item.json.body.name.split(' ')[0] }}, following up on your inquiry",
        "emailType": "html",
        "message": "=<p>Hi {{ $('Webhook — Inbound Lead').item.json.body.name.split(' ')[0] }},</p>\n<p>{{ $('GPT-4o — Qualify Lead').item.json.message.content.personalized_email_opener }}</p>\n<p>{{CLIENT_EMAIL_BODY}}</p>\n<p>{{CLIENT_SIGNATURE}}</p>",
        "options": {}
      },
      "id": "gmail-send-followup",
      "name": "Gmail — Send Follow-up",
      "type": "n8n-nodes-base.gmail",
      "credentials": { "gmailOAuth2": { "id": "{{CLIENT_GOOGLE_CRED_ID}}", "name": "Google OAuth2" } },
      "position": [600, 350]
    },
    {
      "parameters": {
        "sendTo": "={{CLIENT_OWNER_EMAIL}}",
        "subject": "=Unqualified lead: {{ $('Webhook — Inbound Lead').item.json.body.name }} from {{ $('Webhook — Inbound Lead').item.json.body.company }}",
        "message": "=Lead filtered out.\n\nScore: {{ $('GPT-4o — Qualify Lead').item.json.message.content.score }}/10\nReason: {{ $('GPT-4o — Qualify Lead').item.json.message.content.disqualification_reason }}",
        "options": {}
      },
      "id": "gmail-notify-unqualified",
      "name": "Gmail — Log Unqualified",
      "type": "n8n-nodes-base.gmail",
      "credentials": { "gmailOAuth2": { "id": "{{CLIENT_GOOGLE_CRED_ID}}", "name": "Google OAuth2" } },
      "position": [600, 500]
    }
  ],
  "connections": {
    "Webhook — Inbound Lead": { "main": [[{ "node": "GPT-4o — Qualify Lead", "type": "main", "index": 0 }]] },
    "GPT-4o — Qualify Lead": { "main": [[{ "node": "Qualified?", "type": "main", "index": 0 }]] },
    "Qualified?": {
      "main": [
        [
          { "node": "HubSpot — Create Contact", "type": "main", "index": 0 },
          { "node": "Gmail — Send Follow-up", "type": "main", "index": 0 }
        ],
        [{ "node": "Gmail — Log Unqualified", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "meta": { "curcible_product": "P03", "curcible_tier": "growth", "version": "1.0.0" },
  "_SETUP_NOTES": {
    "REPLACE": [
      "{{CLIENT_ID}} — unique slug per client for webhook URL",
      "{{CLIENT_ICP_CRITERIA}} — paste client's ICP definition into system prompt",
      "{{CLIENT_OPENAI_CRED_ID}} — OpenAI credential ID",
      "{{CLIENT_HUBSPOT_CRED_ID}} — HubSpot credential ID (or swap for Airtable node)",
      "{{CLIENT_GOOGLE_CRED_ID}} — Google OAuth2 credential ID",
      "{{CLIENT_EMAIL_BODY}} — client's standard follow-up email body",
      "{{CLIENT_SIGNATURE}} — client's email signature HTML",
      "{{CLIENT_OWNER_EMAIL}} — client owner's email for unqualified lead notifications"
    ],
    "AIRTABLE_ALTERNATIVE": "Replace HubSpot node with Airtable > Create Record node, using the client's leads base"
  }
}
