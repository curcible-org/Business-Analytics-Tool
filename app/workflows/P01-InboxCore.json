    {
      "parameters": { "mode": "append" },
      "id": "merge-fetch",
      "name": "Merge Inboxes",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [700, 500]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const provider = $('⚙️ Config — Set Inbox Provider').item.json.inboxProvider;\nconst raw = $input.item.json;\n\nif (provider === 'gmail') {\n  return {\n    json: {\n      provider: 'gmail',\n      messageId:  raw.id,\n      threadId:   raw.threadId,\n      from:       raw.from || raw.payload?.headers?.find(h => h.name === 'From')?.value || '',\n      subject:    raw.subject || raw.payload?.headers?.find(h => h.name === 'Subject')?.value || '(no subject)',\n      date:       raw.date || raw.internalDate,\n      snippet:    raw.snippet || '',\n    }\n  };\n} else {\n  // Outlook\n  return {\n    json: {\n      provider:   'outlook',\n      messageId:  raw.id,\n      threadId:   raw.conversationId,\n      from:       raw.from?.emailAddress?.address || '',\n      subject:    raw.subject || '(no subject)',\n      date:       raw.receivedDateTime,\n      snippet:    raw.bodyPreview || '',\n    }\n  };\n}"
      },
      "id": "normalize-email",
      "name": "Normalize Email Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 500]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an email triage system. Classify the email and, if appropriate, generate a reply draft.\n\nClassifications:\n- URGENT: Requires immediate human response (complaints, legal, time-sensitive)\n- ROUTINE: Standard inquiry answerable from the knowledge base\n- NEWSLETTER: Marketing, newsletters, no-reply senders\n- SPAM: Junk, phishing, irrelevant\n\nReturn JSON only:\n{\n  \"classification\": \"URGENT|ROUTINE|NEWSLETTER|SPAM\",\n  \"confidence\": 0.0,\n  \"subject_summary\": \"one-line summary\",\n  \"draft_reply\": \"string or null (only for ROUTINE where an answer exists in the KB)\",\n  \"reason\": \"brief explanation\"\n}"
            },
            {
              "role": "user",
              "content": "=From: {{ $json.from }}\nSubject: {{ $json.subject }}\nDate: {{ $json.date }}\n\nBody preview:\n{{ $json.snippet }}\n\nKnowledge base context:\n{{CLIENT_KB_CONTEXT}}"
            }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json_object" } }
        }
      },
      "id": "gpt-classify",
      "name": "GPT-4o — Classify Email",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1,
      "credentials": {
        "openAiApi": { "id": "{{CLIENT_OPENAI_CRED_ID}}", "name": "OpenAI API" }
      },
      "position": [1140, 500]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.message.content.classification }}",
              "rightValue": "ROUTINE",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "if-routine",
      "name": "Is Routine?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1360, 500]
