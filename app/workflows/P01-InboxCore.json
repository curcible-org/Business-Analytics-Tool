                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "Gmail"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $('⚙️ Config — Set Inbox Provider').item.json.inboxProvider }}",
                    "rightValue": "outlook",
                    "operator": { "type": "string", "operation": "equals" }
