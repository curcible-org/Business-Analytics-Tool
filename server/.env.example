# n8n Domain
N8N_HOST=n8n.curcible.com

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York

# n8n Basic Auth — change before deploying
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_strong_password

# Encryption key — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_generate_with_openssl

# Postgres
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme_strong_db_password
